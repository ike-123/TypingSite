generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// model User { 
//   id String @id @default(uuid()) 
//   username String
//   email String @unique
//   passwordHash String 
//   createdAt DateTime @default(now())
// } 

model User {
  id                String              @id
  name              String
  email             String
  emailVerified     Boolean             @default(false)
  image             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  sessions          Session[]
  accounts          Account[]
  typingTests       TypingTest[]
  inventory         UserInventory[]
  UserEquippedItems UserEquippedItems[]
  purchases         Purchases[]
  stripeCustomerId  String?

  Keys        Int     @default(0)
  Ads_Removed Boolean @default(false)
  currency    String  @default("GBP")

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model TypingTest {
  id             String @id @default(uuid())
  userId         String
  wpm            Int
  accuracy       Float
  correctChars   Int
  incorrectChars Int
  duration       Int

  mode                  String
  lengthDurationSetting String

  configKey String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, configKey])
}

enum EquipSlot {
  avatar
  celebration
  character
}

enum GameMode {
  multiplayer
  shooterGame
}

model ShopItem {
  id          String   @id @default(uuid())
  name        String
  description String
  mode        GameMode //Multiplayer, ShooterGame

  slot EquipSlot

  priceKeys Int

  thumbnailUrl String
  ModelUrl     String?
  enabled      Boolean @default(true)

  inventory         UserInventory[]
  userequippedItems UserEquippedItems[]
}

model KeyPackage {
  id String @id @default(uuid())

  //maybe add a type to help webhook logic identify what we are processing?
  name       String
  keysAmount Int //500 for example
  price      Int // 350 (which will be £3.50)
  imageUrl   String?

  purchases Purchases[]
}

model UserInventory {
  id String @id @default(uuid())

  userid String
  itemid String

  user User @relation(fields: [userid], references: [id], onDelete: Cascade)

  //Dont add delete field below as If for whatever I decide to delete a shopItem It should still remain in the users inventory
  //as they paid for it.
  item ShopItem @relation(fields: [itemid], references: [id])

  @@unique([userid, itemid])
}

model UserEquippedItems {
  id String @id @default(uuid())

  userid String
  itemid String

  slot EquipSlot

  // equipped Json

  user User     @relation(fields: [userid], references: [id], onDelete: Cascade)
  item ShopItem @relation(fields: [itemid], references: [id])
}

enum PurchaseType {
  keys
}

model Purchases {
  id String @id @default(uuid())

  userId          String
  stripeSessionId String

  type PurchaseType

  //Store a snapshot 
  itemName  String
  pricePaid Int
  currency  String
  keysGranted Int?

  //OptionalReferences

  keyPackageId String?

  //MerchPackageId 

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  keypackage KeyPackage? @relation(fields: [keyPackageId], references: [id])

  @@unique([stripeSessionId])
}
